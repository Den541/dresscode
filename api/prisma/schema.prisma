generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  refreshTokenHash String?
  preferences  UserPreferences?
  wardrobeItems WardrobeItem[]
  recommendations Recommendation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model UserPreferences {
  id              String @id @default(cuid())
  userId          String @unique
  style           Style  @default(CASUAL)
  coldSensitivity Int    @default(0)
  favoriteCats    Json?
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Style {
  CASUAL
  FORMAL
  SPORTY
}

enum WardrobeCategory {
  OUTERWEAR
  TOPS
  BOTTOMS
  SHOES
  ACCESSORIES
}

model WardrobeItem {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  category  WardrobeCategory
  tags      Json?
  imageUrl  String
  aiAnalysis Json?
  aiAnalyzedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
}

model Recommendation {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city                  String
  weatherSnapshot       Json
  preferencesSnapshot   Json
  recommendedItems      Json
  fromWardrobeItems     Json
  missingItems          Json
  reasons               Json
  selectedWardrobeItemIds Json?
  userComment           String?
  userRating            Int?
  commentedAt           DateTime?
  feedbackAt            DateTime?
  createdAt             DateTime @default(now())

  @@index([userId, createdAt])
}